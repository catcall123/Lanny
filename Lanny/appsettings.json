{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=lanny.db"
  },
  "OuiDataset": {
    "RefreshOnStartup": true,
    "RefreshIntervalHours": 168,
    "SourceUrls": [
      "https://standards-oui.ieee.org/oui/oui.csv",
      "https://standards-oui.ieee.org/cid/cid.csv"
    ]
  },
  "ScanSettings": {
    "Subnet": "auto",
    "ScanIntervalSeconds": 60,
    "ArpScanInterface": "auto",
    "EnableArpScan": true,
    "EnablePingScan": true,
    "EnableMdns": true,
    "EnableDhcpSnooping": true,
    "EnablePassiveArpListener": true,
    "EnableSsdpListener": true,
    "PassiveCaptureInterface": "any",
    "PassiveObservationRetentionMinutes": 5,
    "EnableSnmpInspection": true,
    "SnmpCommunity": "public",
    "SnmpTimeoutMs": 1000,
    "EnableServiceFingerprinting": true,
    "FingerprintTimeoutMs": 1500,
    "FingerprintMaxConcurrency": 8,
    "OfflineThresholdMinutes": 5,
    "OfflineDeviceRetentionHours": 24
  }
}
