{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=lanny.db"
  },
  "ScanSettings": {
    "Subnet": "192.168.1.0/24",
    "ScanIntervalSeconds": 60,
    "EnableArpScan": true,
    "EnablePingScan": true,
    "EnableMdns": true,
    "EnableSnmpInspection": true,
    "SnmpCommunity": "public",
    "SnmpTimeoutMs": 1000,
    "EnableServiceFingerprinting": false,
    "FingerprintTimeoutMs": 1000,
    "FingerprintMaxConcurrency": 4,
    "OfflineThresholdMinutes": 5
  }
}
